# Скопируйте в .env и заполните значения.
# .env не входит в git.

RAPIDAPI_KEY=           # ваш ключ от rapidapi.com
PORT=5050               # не меняйте на 5000 (macOS: AirPlay Receiver)
MOCK_API=false          # true = мок-режим, без расхода квоты

# Только при смене провайдера (по умолчанию — instagram-statistics-api):
# RAPIDAPI_HOST=
# RAPIDAPI_ENDPOINT=
# RAPIDAPI_PARAM_NAME=
# RAPIDAPI_PARAM_MODE=
# RAPIDAPI_AUTH_HEADER=
# RAPIDAPI_HOST_HEADER=

# Phase 1 — путь к SQLite-файлу
# DB_PATH=./data.sqlite
